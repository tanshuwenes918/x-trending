# Feishu Webhook Configuration
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Scraping Configuration
SCRAPE_INTERVAL=3600
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_TRENDS_PER_CATEGORY=10
MAX_TWEETS_PER_TREND=5
X_COUNTRIES=Global,United States
X_CATEGORIES=Technology,News,Business & Finance
X_EXPLORE_URL=https://x.com/explore/tabs/trending
# Optional. Use after confirming the real country/category URL pattern.
# Available variables: {country}, {category}, {country_slug}, {category_slug}
X_CATEGORY_URL_TEMPLATE=

# Debug Mode
DEBUG=false
DRY_RUN=false

# Output Format (feishu, json, both)
OUTPUT_FORMAT=feishu
OUTPUT_DIR=outputs
TIMEZONE=Asia/Shanghai
