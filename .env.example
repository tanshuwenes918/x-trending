# Feishu Webhook Configuration
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Scraping Configuration
SCRAPE_INTERVAL=3600
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_TRENDS_PER_CATEGORY=10
MAX_TWEETS_PER_TREND=5
MAX_ITEMS_PER_GROUP=7
TOP_ACTION_COUNT=5
LOOKBACK_HOURS=24
X_COUNTRIES=Global
X_CATEGORIES=Technology,News,Business & Finance,Science,Travel,Gaming,Sports,Health&Fitness,cryptocurrency,cars,music,dance,celebrity,relationship,movies&tv,nature&outdoors,Entertainment,food,meme,beauty,Pets,fashion,anime,religion,Home & Garden
X_EXPLORE_URL=https://x.com/explore/tabs/trending
# Optional. Use after confirming the real country/category URL pattern.
# Available variables: {country}, {category}, {country_slug}, {category_slug}
X_CATEGORY_URL_TEMPLATE=
# Optional. Paste the full X Cookie request header value locally or in GitHub Secrets.
X_COOKIES=

# OpenAI-compatible LLM Configuration
LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Debug Mode
DEBUG=false
DRY_RUN=false

# Output Format (feishu, json, both)
OUTPUT_FORMAT=feishu
OUTPUT_DIR=outputs
TIMEZONE=Asia/Shanghai
